using Microsoft.EntityFrameworkCore;
using System.ComponentModel.DataAnnotations;
using System.ComponentModel.DataAnnotations.Schema;

namespace ClinicMatch.Domain.Entities;

[Index(nameof(StudentCode), IsUnique = true)]
public class StudentProfile
{
    [Key]
    public int UserId { get; set; }

    [Required, MaxLength(150)]
    public string University { get; set; } = default!;

    [Required, MaxLength(150)]
    public string Faculty { get; set; } = default!;

    [Required]
    public int AcademicYear { get; set; }

    [MaxLength(200)]
    public string? ClinicName { get; set; }

    [MaxLength(100)]
    public string? StudentCode { get; set; }

    [MaxLength(150)]
    public string? SupervisorName { get; set; }

    [Required]
    public int RequiredCasesCount { get; set; }

    [Required]
    public int CompletedCasesCount { get; set; }

    [Required]
    public bool IsVerified { get; set; }

    public DateTime? VerifiedAt { get; set; }

    public User User { get; set; } = default!;
}
